# 後端環境變數範本：複製成 .env 後填入實際值（.env 已被 .gitignore 忽略，勿提交）
# cp .env.example .env

# 伺服器啟動設定
HOST=0.0.0.0
PORT=5174

# 前後端溝通設定
BACKEND_URL=http://localhost:5174
FRONTEND_URL=http://localhost:5173

# Gemini API key（必填；雲端視覺大腦 Gemini 用，啟用 Generative Language API 後在 AI Studio 取得）
# 與下方 GOOGLE_API_KEY 是「不同的兩把金鑰、不同的 API」：程式以 GEMINI_API_KEY 明確帶入，不互相干擾。
# 亦可改由 shell（如 ~/.bashrc 的 export GEMINI_API_KEY=...）提供，二擇一即可。
GEMINI_API_KEY=your-gemini-api-key

# Jamendo 音樂 API（從 https://developer.jamendo.com 取得 client id）
JAMENDO_CLIENT_ID=your-jamendo-client-id

# Logto 認證設定（從 Logto Console 取得後填入；<your-tenant> 換成你的 tenant 代號）
LOGTO_ISSUER=https://<your-tenant>.logto.app/oidc
LOGTO_JWKS_URI=https://<your-tenant>.logto.app/oidc/jwks
LOGTO_AUDIENCE=https://api.<your-tenant>.logto.app/api

# Layer 0 雲端攝取：Google Drive API key（公開資料夾模式）
# 取得方式：Cloud Console → 啟用 Google Drive API → 建立 API 金鑰；
# 目標資料夾需設為「知道連結的人可檢視」(anyone-with-link)
GOOGLE_API_KEY=your-google-drive-api-key
# 是否在啟動時拉起背景輪詢（sandbox／無金鑰開發可設 false）
ENABLE_INGESTION_POLLER=true

# （選填）Layer 0 攝取進階設定，未設定則用括號內預設值
# DRIVE_API_BASE_URL=https://www.googleapis.com/drive/v3
# DRIVE_API_PAGE_SIZE=1000          # 單次 files.list 最大筆數（上限 1000）
# DRIVE_API_TIMEOUT_SEC=120         # 單次 Drive API 請求逾時秒數
# INGESTION_POLL_INTERVAL_SEC=300   # 每個 project 兩次同步最小間隔（秒）
# POLLER_TICK_SEC=60                # poller 迴圈醒來週期（秒）

# （選填）執行期路徑覆寫，預設指向本地 /data1 以避開 NFS hang
# ASSETS_DIR=/data1/cache/mjlee/assets
# TEMP_TEMPLATES_DIR=/data1/cache/mjlee/temp_templates
# TEMP_WORKSPACES_DIR=/data1/cache/mjlee/temp_workspaces
# MODEL_WEIGHTS_DIR=               # 本地模型權重根目錄

# （選填）模型與進度推播調校，未設定用程式內預設
# QWEN_QUANT_MODE=                  # Qwen 量化模式
# WHISPER_MODEL_ID=                 # faster-whisper 模型代號
# WHISPER_CUDA_COMPUTE_TYPE=        # Whisper CUDA 計算精度（如 float16）
# PROGRESS_BUFFER_MAXLEN=2000       # 每 job 進度事件 replay buffer 上限
# PROGRESS_JOB_RETENTION_SEC=1800   # job 結果保留秒數
