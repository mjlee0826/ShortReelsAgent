# 前端環境變數範本：複製成 .env 後填入實際值（.env 已被 frontend/.gitignore 忽略，勿提交）
# cp .env.example .env
# 注意：Vite 只會把 VITE_ 前綴的變數注入到前端

# 後端 API 位址
VITE_BACKEND_URL=http://localhost:5174
# 前端 dev server 連接埠
VITE_PORT=5173

# Logto 認證設定（從 Logto Console 取得後填入；<your-tenant> 換成你的 tenant 代號）
VITE_LOGTO_ENDPOINT=https://<your-tenant>.logto.app/
VITE_LOGTO_APP_ID=your-logto-app-id
VITE_LOGTO_API_RESOURCE=https://api.<your-tenant>.logto.app/api
